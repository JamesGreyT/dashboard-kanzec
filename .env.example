DATABASE_URL=postgresql+asyncpg://dashboard_api:changeme@127.0.0.1:5432/kanzec
KANZEC_JWT_SECRET=replace-with-openssl-rand-hex-32

# Bootstrap admin (read only on first deploy; remove from .env after first login)
KANZEC_ADMIN_USERNAME=admin
KANZEC_ADMIN_PASSWORD=changeme

# Token lifetimes
KANZEC_ACCESS_TOKEN_TTL_SECONDS=900
KANZEC_REFRESH_TOKEN_TTL_SECONDS=604800

# Cookie + CORS
KANZEC_COOKIE_DOMAIN=kanzec.ilhom.work
KANZEC_ALLOWED_ORIGINS=https://kanzec.ilhom.work

TZ=Asia/Tashkent
